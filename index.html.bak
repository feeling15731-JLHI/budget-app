<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="記帳本" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <title>記帳本</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
    :root {
      --bg: #ffffff; --bg2: #f5f5f5; --bg3: #ebebeb;
      --text: #1a1a1a; --text2: #666; --text3: #999;
      --border: rgba(0,0,0,0.1); --border2: rgba(0,0,0,0.2);
      --accent: #378ADD; --success: #1D9E75; --danger: #E24B4A;
      --radius: 12px; --radius-sm: 8px;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1c1c1e; --bg2: #2c2c2e; --bg3: #3a3a3c;
        --text: #f2f2f7; --text2: #aeaeb2; --text3: #6d6d72;
        --border: rgba(255,255,255,0.1); --border2: rgba(255,255,255,0.2);
      }
    }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: -apple-system, 'Helvetica Neue', sans-serif; }
    body { display: flex; flex-direction: column; max-width: 480px; margin: 0 auto; }
    .header { padding: 16px 16px 0; padding-top: max(16px, env(safe-area-inset-top)); background: var(--bg); position: sticky; top: 0; z-index: 10; }
    .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .header-title { font-size: 20px; font-weight: 700; }
    .month-nav { display: flex; align-items: center; gap: 12px; }
    .month-nav button { width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border2); background: var(--bg2); color: var(--text); font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .month-label { font-size: 15px; font-weight: 600; min-width: 90px; text-align: center; }
    .tabs { display: flex; background: var(--bg2); border-radius: var(--radius-sm); padding: 3px; margin: 0 16px 12px; }
    .tab { flex: 1; padding: 7px 4px; text-align: center; font-size: 12px; font-weight: 500; color: var(--text2); border-radius: 6px; cursor: pointer; border: none; background: none; transition: all 0.2s; }
    .tab.active { background: var(--bg); color: var(--text); box-shadow: 0 1px 4px rgba(0,0,0,0.15); }
    .scroll { flex: 1; overflow-y: auto; padding: 0 16px 100px; -webkit-overflow-scrolling: touch; }
    .section { display: none; }
    .section.active { display: block; }
    .metric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
    .metric { background: var(--bg2); border-radius: var(--radius-sm); padding: 12px; }
    .metric-label { font-size: 11px; color: var(--text2); margin-bottom: 3px; }
    .metric-value { font-size: 18px; font-weight: 700; }
    .metric-sub { font-size: 11px; color: var(--text3); margin-top: 1px; }
    .danger-text { color: var(--danger); }
    .success-text { color: var(--success); }
    .card { background: var(--bg2); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
    .card-title { font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 10px; }
    .progress-bar { height: 6px; background: var(--bg3); border-radius: 3px; overflow: hidden; margin: 5px 0 2px; }
    .progress-fill { height: 100%; border-radius: 3px; }
    .expense-row { display: flex; align-items: center; gap: 8px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .expense-row:last-child { border-bottom: none; }
    .cat-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
    .expense-name { flex: 1; font-size: 14px; }
    .expense-amount { font-size: 13px; font-weight: 600; }
    .expense-pct { font-size: 11px; color: var(--text3); min-width: 36px; text-align: right; }
    .del-btn { width: 24px; height: 24px; border-radius: 50%; background: var(--bg3); border: none; color: var(--text3); cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .add-form { background: var(--bg2); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
    .add-form-title { font-size: 13px; font-weight: 600; color: var(--text2); margin-bottom: 10px; }
    .form-row { display: flex; gap: 8px; margin-bottom: 8px; }
    .form-row:last-child { margin-bottom: 0; }
    input, select { height: 40px; border: 1px solid var(--border2); border-radius: var(--radius-sm); background: var(--bg); color: var(--text); font-size: 14px; padding: 0 10px; width: 100%; outline: none; }
    input:focus, select:focus { border-color: var(--accent); }
    .btn-primary { height: 40px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 14px; font-weight: 600; cursor: pointer; width: 100%; }
    .btn-secondary { height: 36px; background: var(--bg3); color: var(--text); border: none; border-radius: var(--radius-sm); font-size: 13px; font-weight: 500; cursor: pointer; padding: 0 14px; white-space: nowrap; }
    .cat-section { margin-bottom: 12px; }
    .cat-header { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: var(--bg2); border-radius: var(--radius) var(--radius) 0 0; }
    .cat-header-name { flex: 1; font-size: 14px; font-weight: 600; }
    .cat-total { font-size: 13px; color: var(--text2); }
    .cat-body { background: var(--bg2); border-radius: 0 0 var(--radius) var(--radius); padding: 0 14px; border-top: 1px solid var(--border); }
    .income-card { background: var(--bg2); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
    .income-label { font-size: 13px; color: var(--text2); margin-bottom: 8px; font-weight: 600; }
    .cat-manage-row { display: flex; align-items: center; gap: 10px; padding: 11px 0; border-bottom: 1px solid var(--border); }
    .cat-manage-row:last-child { border-bottom: none; }
    .chart-wrap { position: relative; width: 100%; height: 200px; }
    .empty { text-align: center; padding: 24px; color: var(--text3); font-size: 13px; }
    .bottom-pad { height: max(16px, env(safe-area-inset-bottom)); }
  </style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <div class="header-title">💶 記帳本</div>
    <div class="month-nav">
      <button onclick="changeMonth(-1)">&#8249;</button>
      <span class="month-label" id="month-label">--</span>
      <button onclick="changeMonth(1)">&#8250;</button>
    </div>
  </div>
  <div class="tabs">
    <button class="tab active" onclick="showTab('overview')">總覽</button>
    <button class="tab" onclick="showTab('expenses')">支出</button>
    <button class="tab" onclick="showTab('categories')">分類</button>
    <button class="tab" onclick="showTab('history')">趨勢</button>
  </div>
</div>

<div class="scroll">

  <div class="section active" id="tab-overview">
    <div class="income-card">
      <div class="income-label">月收入（歐元 €）</div>
      <div style="display:flex;gap:8px;">
        <input type="number" id="income-input" placeholder="輸入每月收入" inputmode="decimal" step="0.01" oninput="updateIncome()" />
      </div>
    </div>
    <div class="metric-grid" id="metrics"></div>
    <div class="card">
      <div class="card-title">各分類支出</div>
      <div id="cat-breakdown"></div>
    </div>
    <div class="card">
      <div class="card-title">近 6 個月支出 vs 收入</div>
      <div class="chart-wrap">
        <canvas id="overviewChart" role="img" aria-label="近6個月支出與收入長條圖">支出趨勢圖</canvas>
      </div>
    </div>
  </div>

  <div class="section" id="tab-expenses">
    <div class="add-form">
      <div class="add-form-title">新增支出</div>
      <div class="form-row">
        <input type="text" id="new-name" placeholder="說明（如：Albert Heijn、房租）" />
      </div>
      <div class="form-row">
        <input type="number" id="new-amount" placeholder="金額 €" inputmode="decimal" step="0.01" style="flex:1;" />
        <select id="new-cat" style="flex:1;"></select>
      </div>
      <div class="form-row">
        <button class="btn-primary" onclick="addExpense()">+ 新增</button>
      </div>
    </div>
    <div id="expense-sections"></div>
  </div>

  <div class="section" id="tab-categories">
    <div class="card">
      <div class="card-title">我的分類</div>
      <div id="cat-list"></div>
      <div class="form-row" style="margin-top:12px;">
        <input type="text" id="new-cat-name" placeholder="新增分類名稱" />
        <button class="btn-secondary" onclick="addCategory()">新增</button>
      </div>
    </div>
  </div>

  <div class="section" id="tab-history">
    <div class="card">
      <div class="card-title">各分類趨勢（近6個月）</div>
      <div class="chart-wrap" style="height:220px;">
        <canvas id="histChart" role="img" aria-label="近6個月各分類支出折線圖">分類趨勢圖</canvas>
      </div>
    </div>
    <div class="card">
      <div class="card-title">月平均支出</div>
      <div id="avg-breakdown"></div>
    </div>
  </div>

  <div class="bottom-pad"></div>
</div>

<script>
const CAT_COLORS = ['#378ADD','#1D9E75','#D85A30','#D4537E','#7F77DD','#BA7517','#639922','#E24B4A','#888780','#0F6E56'];
const MONTHS = ['Jan','Feb','Mrt','Apr','Mei','Jun','Jul','Aug','Sep','Okt','Nov','Dec'];

function fmt(n) {
  return '\u20ac\u00a0' + n.toLocaleString('nl-NL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function fmtShort(v) {
  if (v >= 1000) return '\u20ac' + (v/1000).toFixed(1) + 'k';
  return '\u20ac' + Math.round(v);
}

function loadState() {
  try { const s = localStorage.getItem('budget_eu_v1'); if (s) return JSON.parse(s); } catch(e) {}
  return null;
}
function saveState() {
  try { localStorage.setItem('budget_eu_v1', JSON.stringify(state)); } catch(e) {}
}

let state = loadState() || {
  income: 3000,
  currentMonth: new Date().getMonth(),
  currentYear: new Date().getFullYear(),
  categories: [
    { id: 1, name: '固定支出' },
    { id: 2, name: '餐飲食材' },
    { id: 3, name: '交通' },
    { id: 4, name: '娛樂' },
    { id: 5, name: '其他' }
  ],
  expenses: {}
};

state.currentMonth = parseInt(state.currentMonth);
state.currentYear = parseInt(state.currentYear);

function monthKey(y, m) { return y + '-' + String(m+1).padStart(2,'0'); }
function curKey() { return monthKey(state.currentYear, state.currentMonth); }
function getExpenses(key) { return state.expenses[key] || []; }
function totalExpenses(key) { return getExpenses(key).reduce(function(s,e){ return s+e.amount; }, 0); }
function catColor(catId) {
  var idx = state.categories.findIndex(function(c){ return c.id===catId; });
  return CAT_COLORS[Math.max(0,idx) % CAT_COLORS.length];
}

function init() {
  var mk = curKey();
  if (!state.expenses[mk]) {
    state.expenses[mk] = [
      { id: 1, name: '房租', amount: 1200, catId: 1 },
      { id: 2, name: '水電 / Gas', amount: 120, catId: 1 },
      { id: 3, name: '電話費', amount: 25, catId: 1 },
      { id: 4, name: 'Zorgverzekering', amount: 140, catId: 1 },
      { id: 5, name: 'Albert Heijn', amount: 280, catId: 2 },
      { id: 6, name: '外食', amount: 150, catId: 2 },
      { id: 7, name: 'OV-chipkaart', amount: 80, catId: 3 }
    ];
    saveState();
  }
  document.getElementById('income-input').value = state.income;
  render();
}

function showTab(id) {
  var names = ['overview','expenses','categories','history'];
  document.querySelectorAll('.tab').forEach(function(t,i){ t.classList.toggle('active', names[i]===id); });
  document.querySelectorAll('.section').forEach(function(s){ s.classList.remove('active'); });
  document.getElementById('tab-'+id).classList.add('active');
  render();
}

function changeMonth(d) {
  state.currentMonth += d;
  if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
  if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
  saveState(); render();
}

function updateIncome() {
  state.income = parseFloat(document.getElementById('income-input').value) || 0;
  saveState(); render();
}

function getLast6Months() {
  var months = [], y = state.currentYear, m = state.currentMonth;
  for (var i = 5; i >= 0; i--) {
    var mm = m - i, yy = y;
    while (mm < 0) { mm += 12; yy--; }
    months.push({ key: monthKey(yy, mm), label: MONTHS[mm] });
  }
  return months;
}

function render() {
  document.getElementById('month-label').textContent = MONTHS[state.currentMonth] + ' ' + state.currentYear;
  renderMetrics();
  renderCatBreakdown();
  renderExpenseList();
  renderCatList();
  renderAvg();
  renderCharts();
}

function renderMetrics() {
  var key = curKey();
  var total = totalExpenses(key);
  var income = state.income;
  var remain = income - total;
  var pct = income > 0 ? (total / income * 100) : 0;
  document.getElementById('metrics').innerHTML =
    '<div class="metric"><div class="metric-label">本月支出</div><div class="metric-value">' + fmt(total) + '</div></div>' +
    '<div class="metric"><div class="metric-label">月收入</div><div class="metric-value">' + fmt(income) + '</div></div>' +
    '<div class="metric"><div class="metric-label">支出佔比</div><div class="metric-value ' + (pct>90?'danger-text':pct>70?'':'success-text') + '">' + pct.toFixed(1) + '%</div><div class="metric-sub">佔收入</div></div>' +
    '<div class="metric"><div class="metric-label">結餘</div><div class="metric-value ' + (remain<0?'danger-text':'success-text') + '">' + fmt(remain) + '</div></div>';
}

function renderCatBreakdown() {
  var key = curKey();
  var exps = getExpenses(key);
  var total = totalExpenses(key);
  var income = state.income;
  var html = '';
  state.categories.forEach(function(cat) {
    var sum = exps.filter(function(e){ return e.catId===cat.id; }).reduce(function(s,e){ return s+e.amount; },0);
    if (!sum) return;
    var pctT = total > 0 ? (sum/total*100) : 0;
    var pctI = income > 0 ? (sum/income*100) : 0;
    var color = catColor(cat.id);
    html += '<div style="margin-bottom:12px;">' +
      '<div style="display:flex;align-items:center;gap:8px;">' +
        '<span class="cat-dot" style="background:'+color+';"></span>' +
        '<span style="flex:1;font-size:14px;">'+cat.name+'</span>' +
        '<span style="font-size:14px;font-weight:600;">'+fmt(sum)+'</span>' +
        '<span style="font-size:11px;color:var(--text3);min-width:36px;text-align:right;">'+pctT.toFixed(1)+'%</span>' +
      '</div>' +
      '<div class="progress-bar"><div class="progress-fill" style="width:'+Math.min(pctI,100)+'%;background:'+color+';"></div></div>' +
      '<div style="font-size:11px;color:var(--text3);">佔收入 '+pctI.toFixed(1)+'%</div>' +
    '</div>';
  });
  document.getElementById('cat-breakdown').innerHTML = html || '<div class="empty">本月尚無支出</div>';
}

function renderExpenseList() {
  var key = curKey();
  var exps = getExpenses(key);
  var total = totalExpenses(key);
  var sel = document.getElementById('new-cat');
  if (sel) sel.innerHTML = state.categories.map(function(c){ return '<option value="'+c.id+'">'+c.name+'</option>'; }).join('');
  var html = '';
  state.categories.forEach(function(cat) {
    var items = exps.filter(function(e){ return e.catId===cat.id; });
    var sum = items.reduce(function(s,e){ return s+e.amount; },0);
    var color = catColor(cat.id);
    html += '<div class="cat-section"><div class="cat-header">' +
      '<span class="cat-dot" style="background:'+color+';width:10px;height:10px;"></span>' +
      '<span class="cat-header-name">'+cat.name+'</span>' +
      '<span class="cat-total">'+fmt(sum)+'</span>' +
    '</div><div class="cat-body">';
    if (!items.length) html += '<div class="empty">尚無項目</div>';
    items.forEach(function(exp) {
      var pct = total > 0 ? (exp.amount/total*100).toFixed(1) : 0;
      html += '<div class="expense-row">' +
        '<span class="expense-name">'+exp.name+'</span>' +
        '<span class="expense-amount">'+fmt(exp.amount)+'</span>' +
        '<span class="expense-pct">'+pct+'%</span>' +
        '<button class="del-btn" onclick="deleteExpense('+exp.id+')">&#215;</button>' +
      '</div>';
    });
    html += '</div></div>';
  });
  var el = document.getElementById('expense-sections');
  if (el) el.innerHTML = html;
}

function addExpense() {
  var name = document.getElementById('new-name').value.trim();
  var amount = parseFloat(document.getElementById('new-amount').value);
  var catId = parseInt(document.getElementById('new-cat').value);
  if (!name || isNaN(amount) || amount <= 0) { alert('請填寫說明與金額'); return; }
  var key = curKey();
  if (!state.expenses[key]) state.expenses[key] = [];
  state.expenses[key].push({ id: Date.now(), name: name, amount: Math.round(amount*100)/100, catId: catId });
  document.getElementById('new-name').value = '';
  document.getElementById('new-amount').value = '';
  saveState(); render();
}

function deleteExpense(id) {
  if (!confirm('確定刪除？')) return;
  var key = curKey();
  state.expenses[key] = (state.expenses[key]||[]).filter(function(e){ return e.id!==id; });
  saveState(); render();
}

function renderCatList() {
  var el = document.getElementById('cat-list');
  if (!el) return;
  el.innerHTML = state.categories.map(function(cat,i) {
    return '<div class="cat-manage-row">' +
      '<span class="cat-dot" style="background:'+CAT_COLORS[i%CAT_COLORS.length]+';width:12px;height:12px;"></span>' +
      '<span style="flex:1;font-size:14px;">'+cat.name+'</span>' +
      (state.categories.length>1 ? '<button class="del-btn" onclick="deleteCategory('+cat.id+')">&#215;</button>' : '') +
    '</div>';
  }).join('');
}

function addCategory() {
  var input = document.getElementById('new-cat-name');
  var name = input.value.trim();
  if (!name) return;
  state.categories.push({ id: Date.now(), name: name });
  input.value = '';
  saveState(); render();
}

function deleteCategory(id) {
  var inUse = Object.values(state.expenses).some(function(arr){ return arr.some(function(e){ return e.catId===id; }); });
  if (inUse) { alert('此分類有支出項目，請先刪除相關支出再刪分類。'); return; }
  state.categories = state.categories.filter(function(c){ return c.id!==id; });
  saveState(); render();
}

function renderAvg() {
  var el = document.getElementById('avg-breakdown');
  if (!el) return;
  var months = getLast6Months().filter(function(m){ return getExpenses(m.key).length>0; });
  if (!months.length) { el.innerHTML='<div class="empty">尚無足夠資料</div>'; return; }
  var html = '', grandTotal = 0;
  state.categories.forEach(function(cat) {
    var sums = months.map(function(m){ return getExpenses(m.key).filter(function(e){ return e.catId===cat.id; }).reduce(function(s,e){ return s+e.amount; },0); });
    var avg = sums.reduce(function(a,b){ return a+b; },0)/months.length;
    if (!avg) return;
    grandTotal += avg;
    var color = catColor(cat.id);
    var pctI = state.income>0?(avg/state.income*100).toFixed(1):'-';
    html += '<div style="display:flex;align-items:center;gap:8px;padding:9px 0;border-bottom:1px solid var(--border);">' +
      '<span class="cat-dot" style="background:'+color+';"></span>' +
      '<span style="flex:1;font-size:14px;">'+cat.name+'</span>' +
      '<span style="font-size:14px;font-weight:600;">'+fmt(avg)+'</span>' +
      '<span style="font-size:11px;color:var(--text3);min-width:52px;text-align:right;">佔收入 '+pctI+'%</span>' +
    '</div>';
  });
  var pctG = state.income>0?(grandTotal/state.income*100).toFixed(1):'-';
  html += '<div style="display:flex;gap:8px;padding:10px 0 0;font-weight:700;">' +
    '<span style="flex:1;font-size:14px;">月平均合計</span>' +
    '<span style="font-size:14px;">'+fmt(grandTotal)+'</span>' +
    '<span style="font-size:11px;color:var(--text3);min-width:52px;text-align:right;">佔收入 '+pctG+'%</span>' +
  '</div>';
  el.innerHTML = html;
}

var overviewChart = null, histChart = null;
function renderCharts() {
  var months = getLast6Months();
  var labels = months.map(function(m){ return m.label; });
  var totals = months.map(function(m){ return totalExpenses(m.key); });

  var oc = document.getElementById('overviewChart');
  if (oc) {
    if (overviewChart) overviewChart.destroy();
    overviewChart = new Chart(oc, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          { label: '支出', data: totals, backgroundColor: '#378ADD', borderRadius: 4 },
          { label: '收入', data: labels.map(function(){ return state.income; }), backgroundColor: 'rgba(29,158,117,0.25)', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position:'top', labels: { font:{size:11}, boxWidth:12 } } },
        scales: {
          y: { ticks: { callback: function(v){ return fmtShort(v); }, font:{size:10} } },
          x: { ticks: { font:{size:10}, autoSkip:false } }
        }
      }
    });
  }

  var hc = document.getElementById('histChart');
  if (hc) {
    if (histChart) histChart.destroy();
    var datasets = state.categories.map(function(cat,i){
      return {
        label: cat.name,
        data: months.map(function(m){ return getExpenses(m.key).filter(function(e){ return e.catId===cat.id; }).reduce(function(s,e){ return s+e.amount; },0); }),
        borderColor: CAT_COLORS[i%CAT_COLORS.length],
        backgroundColor: CAT_COLORS[i%CAT_COLORS.length]+'22',
        tension: 0.3, fill: false, pointRadius: 3
      };
    });
    histChart = new Chart(hc, {
      type: 'line',
      data: { labels: labels, datasets: datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position:'top', labels: { font:{size:10}, boxWidth:10, usePointStyle:true } } },
        scales: {
          y: { ticks: { callback: function(v){ return fmtShort(v); }, font:{size:10} } },
          x: { ticks: { font:{size:10}, autoSkip:false } }
        }
      }
    });
  }
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(function(){});
}

init();
</script>
</body>
</html>
